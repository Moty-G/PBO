{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",


    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",

    "noImplicitAny": true,
    "noImplicitOverride": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    
    "strict": true

  },
  "include": ["src/**/*"]
}
